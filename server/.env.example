# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change_me_long_random_string

# Database — PostgreSQL (browse with pgAdmin, see docs/pgadmin-setup.md)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/learndb"

# Cache / job queue
REDIS_URL="redis://localhost:6379"

# LLM providers
# Groq powers the legacy game-arcade content generation (hints, explanations, tutorials)
GROQ_API_KEY=
GEMINI_API_KEY=
# Anthropic powers the assessment platform: solve-and-verify, DSA generation, AI interview
ANTHROPIC_API_KEY=

# Code execution sandbox — Piston (docker-compose.yml at repo root)
PISTON_URL="http://localhost:2000"

# Optional integrations
FIREBASE_DATABASE_URL=
